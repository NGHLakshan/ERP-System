# ================================================================
# ENVIRONMENT VARIABLES - Copy this to .env for local development
# For production (Render.com), set these in the dashboard
# ================================================================

# --- REQUIRED ---
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# --- ENVIRONMENT ---
# Local: True | Production (Render): False
DEBUG=False

# --- HOSTS ---
# Local: 127.0.0.1,localhost
# Production: your-app-name.onrender.com
ALLOWED_HOSTS=your-app-name.onrender.com

# --- DATABASE ---
# Local: leave empty (uses SQLite automatically)
# Production: paste Supabase or Render PostgreSQL URL here
DATABASE_URL=postgres://user:password@host:port/dbname

# --- CORS (Frontend URL) ---
# Local: http://localhost:5173
# Production: your Netlify URL
CORS_ALLOWED_ORIGINS=https://your-app.netlify.app

# --- CSRF ---
# Same as CORS_ALLOWED_ORIGINS
CSRF_TRUSTED_ORIGINS=https://your-app.netlify.app
